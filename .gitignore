# Python
__pycache__/
*.py[cod]
*.egg-info/
build/
dist/

# Virtual environment
.venv/

# Data (preserve src/quantstack/data/ source module)
data/
!src/quantstack/data
*.duckdb
*.db

# Logs
logs/
*.log

