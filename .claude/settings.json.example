{
  "mcpServers": {
    "quantpod": {
      "command": "quantstack-mcp",
      "type": "stdio"
    },
    "quantcore": {
      "command": "quantstack-mcp",
      "type": "stdio"
    }
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "run_analysis",
        "hooks": [
          {
            "type": "command",
            "command": "quantpod-validate-brief",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "execute_trade",
        "hooks": [
          {
            "type": "command",
            "command": "quantpod-log-decision",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "register_strategy",
        "hooks": [
          {
            "type": "command",
            "command": "quantpod-log-decision",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
